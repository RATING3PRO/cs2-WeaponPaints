<!DOCTYPE html>
<html lang="en" <%- webStyleDark ? 'data-bs-theme="dark"' : '' %>>

<head>
	<meta charset="utf-8">
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
	<script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.0/dist/js/bootstrap.min.js"></script>
	<link rel="stylesheet" href="/style.css">
	<title>CS2 Simple Weapon Paints</title>
</head>

<body>

	<% if (!user) { %>
		<div class='bg-primary'>
            <h2>To choose weapon paints loadout, you need to 
                <a href='/auth/steam'><img src='https://steamcommunity-a.akamaihd.net/public/images/signinthroughsteam/sits_01.png'></a>
            </h2>
        </div>
	<% } else { %>
		<div class='bg-primary'>
            <h2>Your current weapon skin loadout <a class='btn btn-danger' href='/logout'>Logout</a></h2>
        </div>
		<div class='card-group mt-2'>

		<div class="col-sm-2">
			<div class="card text-center mb-3 border border-primary">
				<div class="card-body">
					<% 
					let actualKnife = knifes[0];
					if (selectedKnife && selectedKnife.length > 0) {
						for (const key in knifes) {
							if (selectedKnife[0].knife === knifes[key].weapon_name) {
								actualKnife = knifes[key];
								break;
							}
						}
					}
					%>
					<div class='card-header'>
					    <h6 class='card-title item-name'>Knife type</h6>
					    <h5 class='card-title item-name'><%= actualKnife.paint_name %></h5>
					</div>
					<img src='<%= actualKnife.image_url %>' class='skin-image'>
				</div>
				<div class="card-footer">
					<form action="/" method="POST">
						<select name="forma" class="form-control select SelectWeapon" onchange="this.form.submit()">
							<option disabled>Select knife</option>
							<% for (const knifeKey in knifes) { %>
								<option value="knife-<%= knifeKey %>" <%= (selectedKnife && selectedKnife.length > 0 && selectedKnife[0].knife === knifes[knifeKey].weapon_name) ? 'selected' : '' %>><%= knifes[knifeKey].paint_name %></option>
							<% } %>
						</select>
					</form>
				</div>
			</div>
		</div>

		<% for (const defindex in weapons) { %>
            <% const defaultWeapon = weapons[defindex]; %>
			<div class="col-sm-2">
				<div class="card text-center mb-3">
					<div class="card-body">
						<% if (selectedSkins[defindex]) { %>
							<div class='card-header'>
							    <h5 class='card-title item-name'><%= skins[defindex][selectedSkins[defindex].weapon_paint_id].paint_name %></h5>
							</div>
							<img src='<%= skins[defindex][selectedSkins[defindex].weapon_paint_id].image_url %>' class='skin-image'>
						<% } else { %>
							<div class='card-header'>
							    <h5 class='card-title item-name'><%= defaultWeapon.paint_name %></h5>
							</div>
							<img src='<%= defaultWeapon.image_url %>' class='skin-image'>
						<% } %>
					</div>
					<div class="card-footer">
						<form action="/" method="POST">
							<select name="forma" class="form-control select SelectWeapon" onchange="this.form.submit()">
								<option disabled>Select skin</option>
								<% for (const paintKey in skins[defindex]) { %>
                                    <% const paint = skins[defindex][paintKey]; %>
									<option value="<%= defindex %>-<%= paintKey %>" <%= (selectedSkins[defindex] && selectedSkins[defindex].weapon_paint_id == paintKey) ? 'selected' : '' %>><%= paint.paint_name %></option>
								<% } %>
							</select>
							<br></br>
							<% if (selectedSkins[defindex]) { %>
								<button type="button" class="btn btn-primary" data-toggle="modal" data-target="#weaponModal<%= defindex %>">
									Settings
								</button>
							<% } else { %>
								<button type="button" class="btn btn-primary" onclick="showSkinSelectionAlert()">
									Settings
								</button>
							<% } %>
					</div>

					<% 
					const selectedSkinInfo = selectedSkins[defindex] || null;
					const initialWearValue = selectedSkinInfo && selectedSkinInfo.weapon_wear !== undefined && selectedSkinInfo.weapon_wear !== null ? selectedSkinInfo.weapon_wear : 0.0;
					const initialSeedValue = selectedSkinInfo && selectedSkinInfo.weapon_seed !== undefined && selectedSkinInfo.weapon_seed !== null ? selectedSkinInfo.weapon_seed : 0;
					%>

					<div class="modal fade" id="weaponModal<%= defindex %>" tabindex="-1" role="dialog" aria-labelledby="weaponModalLabel<%= defindex %>" aria-hidden="true">
						<div class="modal-dialog" role="document">
							<div class="modal-content">
								<div class="modal-header">
									<h5 class='card-title item-name'>
										<% if (selectedSkins[defindex]) { %>
											<%= skins[defindex][selectedSkins[defindex].weapon_paint_id].paint_name %> Settings
										<% } else { %>
											<%= defaultWeapon.paint_name %> Settings
										<% } %>
									</h5>
								</div>
								<div class="modal-body">
									<div class="form-group">
										<select class="form-select" id="wearSelect<%= defindex %>" name="wearSelect" onchange="updateWearValue<%= defindex %>(this.value)">
											<option disabled>Select Wear</option>
											<option value="0.00" <%= initialWearValue === 0.00 ? 'selected' : '' %>>Factory New</option>
											<option value="0.07" <%= initialWearValue === 0.07 ? 'selected' : '' %>>Minimal Wear</option>
											<option value="0.15" <%= initialWearValue === 0.15 ? 'selected' : '' %>>Field-Tested</option>
											<option value="0.38" <%= initialWearValue === 0.38 ? 'selected' : '' %>>Well-Worn</option>
											<option value="0.45" <%= initialWearValue === 0.45 ? 'selected' : '' %>>Battle-Scarred</option>
										</select>
									</div>
									<div class="row">
										<div class="col-md-6">
											<div class="form-group">
												<label for="wear">Wear:</label>
												<input type="text" value="<%= initialWearValue %>" class="form-control" id="wear<%= defindex %>" name="wear">
											</div>
										</div>
										<div class="col-md-6">
											<div class="form-group">
												<label for="seed">Seed:</label>
												<input type="text" value="<%= initialSeedValue %>" class="form-control" id="seed<%= defindex %>" name="seed" oninput="validateSeed(this)">
											</div>
										</div>
									</div>
								</div>
								<div class="modal-footer">
									<button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
									<button type="submit" class="btn btn-danger">Use</button>
									</form>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
			<script>
				// wear
				function updateWearValue<%= defindex %>(selectedValue) {
					var wearInputElement = document.getElementById("wear<%= defindex %>");
					wearInputElement.value = selectedValue;
				}

				function validateWear(inputElement) {
					inputElement.value = inputElement.value.replace(/[^0-9]/g, '');
				}
				// seed
				function validateSeed(input) {
					var inputValue = input.value.replace(/[^0-9]/g, '');

					if (inputValue === "") {
						input.value = 0;
					} else {
						var numericValue = parseInt(inputValue);
						numericValue = Math.min(1000, Math.max(1, numericValue));

						input.value = numericValue;
					}
				}
			</script>
		<% } %>
	<% } %>
	</div>
	<% if (user) { %>
	</div>
	<% } %>
    
    <% if (user) { %>
    <script>
        function showSkinSelectionAlert() {
            alert("You need to select a skin first.");
        }
    </script>
    <% } %>

	<div class="container">
		<footer class="d-flex flex-wrap justify-content-between align-items-center py-3 my-4 border-top">
			<div class="col-md-4 d-flex align-items-center">
				<span class="mb-3 mb-md-0 text-body-secondary">© 2023 <a href="https://github.com/Nereziel/cs2-WeaponPaints">Nereziel/cs2-WeaponPaints</a></span>
			</div>
		</footer>
	</div>
</body>

</html>